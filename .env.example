SECRET_KEY=change-this-to-a-random-secret-value
ADMIN_EMAIL=admin@olivegate.com
ADMIN_PASSWORD=change-this-admin-password
PORT=5000
FLASK_DEBUG=true

# Shared password for the "Admin Login" page (/admin-login). Anyone who enters
# this password there is granted (or promoted to) an admin account, using
# whatever email they type in. Keep this secret; only share it with people
# who should be able to manage the hostel. If unset, the Admin Login page
# is disabled.
ADMIN_ACCESS_CODE=change-this-to-a-shared-admin-secret

# Email notifications (registration & loan applications).
# MAIL_USERNAME must be a Gmail address with 2-Step Verification enabled;
# MAIL_PASSWORD must be a 16-character App Password from
# https://myaccount.google.com/apppasswords (NOT your normal Gmail password).
# Notifications are skipped silently if these are left unset.
MAIL_USERNAME=your-sending-address@gmail.com
MAIL_PASSWORD=your-16-char-app-password
